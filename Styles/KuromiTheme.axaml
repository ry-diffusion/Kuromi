<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Kuromi.Controls"
        xmlns:glass="using:Kuromi.Glass">

    <!-- Colors live in Styles/Palette.axaml (merged in App.axaml); these styles
         consume them via DynamicResource. -->

    <!-- Touch kiosk: no focus rectangle on buttons/sliders (incl. the glass controls). -->
    <Style Selector=":is(Button)">
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>
    <Style Selector=":is(Slider)">
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <!-- Card container -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardStroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="22"/>
        <Setter Property="BoxShadow" Value="0 18 50 0 #55000000"/>
    </Style>

    <!-- Headings & text -->
    <Style Selector="TextBlock.h1">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="TextBlock.label">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>
    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style Selector="TextBlock.metric">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontSize" Value="26"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- Widget header glyph (uses icon font) -->
    <Style Selector="TextBlock.glyph">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="FontFamily" Value="{DynamicResource IconFont}"/>
        <Setter Property="FontSize" Value="16"/>
    </Style>

    <!-- Pill button (touch friendly) -->
    <Style Selector=":is(Button).pill">
        <Setter Property="Background" Value="{DynamicResource ControlFill}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="22"/>
        <Setter Property="Padding" Value="18,12"/>
        <Setter Property="MinHeight" Value="48"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.pill:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ControlFillHover}"/>
    </Style>

    <!-- Accent pill -->
    <Style Selector=":is(Button).accent">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <!-- Glass ignores Background, so accent glass buttons tint their surface with the accent color. -->
    <Style Selector="glass|GlassButton.accent">
        <Setter Property="SurfaceColor" Value="{DynamicResource AccentColor}"/>
    </Style>

    <!-- Round icon button (matches Button AND ToggleButton via :is) -->
    <Style Selector=":is(Button).icon">
        <Setter Property="Background" Value="{DynamicResource ControlFill}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="{DynamicResource IconFont}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="24"/>
        <Setter Property="Width" Value="48"/>
        <Setter Property="Height" Value="48"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ControlFillHover}"/>
    </Style>

    <!-- Virtual keyboard key -->
    <Style Selector=":is(Button).key">
        <Setter Property="Background" Value="{DynamicResource ControlFill}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="9"/>
        <Setter Property="Margin" Value="3"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.key:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ControlFillHover}"/>
    </Style>

    <!-- Pretty checkbox (rounded box + Lucide check, accent when checked) -->
    <Style Selector="ToggleButton.check">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="box" CornerRadius="9"
                        Background="{DynamicResource ControlFill}"
                        BorderBrush="{DynamicResource CardStroke}" BorderThickness="1.5">
                    <controls:LucideIcon Name="chk" Kind="check" Width="16" Height="16"
                                         StrokeThickness="2.4" Brush="{DynamicResource OnAccentBrush}" Opacity="0"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="ToggleButton.check:checked /template/ Border#box">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="ToggleButton.check:checked /template/ controls|LucideIcon#chk">
        <Setter Property="Opacity" Value="1"/>
    </Style>

    <!-- Text input -->
    <Style Selector="TextBox.kuromi">
        <Setter Property="Background" Value="{DynamicResource ControlFill}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="14,12"/>
        <Setter Property="MinHeight" Value="46"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style Selector="ScrollViewer">
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
    </Style>
</Styles>
