<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kuromi.ViewModels.Widgets"
             x:Class="Kuromi.Views.Widgets.AppListView"
             x:DataType="vm:AppListViewModel">
    <Grid RowDefinitions="Auto,*">
        <TextBlock Grid.Row="0" Classes="muted" Margin="2,0,0,8"
                   Text="{Binding GroupCount, StringFormat='{}{0} aplicativos · agrupados por nome'}"/>

        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Apps}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:AppItemViewModel">
                        <Border CornerRadius="14" Background="{DynamicResource RowFill}" Margin="0,0,0,6" Padding="10,8">
                            <Grid ColumnDefinitions="44,*,Auto">
                                <!-- Icon / fallback -->
                                <Panel Grid.Column="0" Width="36" Height="36">
                                    <Border CornerRadius="10" IsVisible="{Binding !HasIcon}"
                                            Background="{DynamicResource AccentBrush}">
                                        <TextBlock Text="{Binding Initial}" Foreground="{DynamicResource OnAccentBrush}"
                                                   FontWeight="Bold" FontSize="16"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Image Source="{Binding IconPath, Converter={StaticResource PathToBitmap}}"
                                           IsVisible="{Binding HasIcon}" Width="36" Height="36"/>
                                </Panel>

                                <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="15" FontWeight="Medium"/>
                                        <TextBlock Text="{Binding CountText}" Classes="muted"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}" FontSize="14"
                                           FontWeight="SemiBold"
                                           Text="{Binding MemBytes, Converter={StaticResource BytesToHuman}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
