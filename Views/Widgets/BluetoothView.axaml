<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kuromi.ViewModels.Widgets"
             xmlns:controls="using:Kuromi.Controls"
             x:Class="Kuromi.Views.Widgets.BluetoothView"
             x:DataType="vm:BluetoothViewModel">
    <Grid>
        <TextBlock IsVisible="{Binding !Available}" Classes="muted"
                   VerticalAlignment="Center" HorizontalAlignment="Center"
                   Text="bluetoothctl não encontrado"/>

        <Grid IsVisible="{Binding Available}" RowDefinitions="Auto,*">
            <!-- Controls -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,0,0,10">
                <ToggleSwitch Grid.Column="0" IsChecked="{Binding Powered, Mode=OneWay}"
                              Command="{Binding TogglePowerCommand}"
                              OnContent="Ligado" OffContent="Desligado"
                              VerticalAlignment="Center"/>
                <Button Grid.Column="2" Classes="pill" Margin="6,0"
                        Command="{Binding ScanCommand}" IsEnabled="{Binding Powered}"
                        Content="Procurar"/>
                <Button Grid.Column="3" Classes="icon" Width="44" Height="44"
                        Command="{Binding RefreshCommand}" IsEnabled="{Binding Powered}">
                    <controls:LucideIcon Kind="refresh-cw" Width="18" Height="18"
                                         Brush="{DynamicResource TextPrimary}"/>
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1">
                <StackPanel>
                    <TextBlock Text="procurando dispositivos…" Classes="muted"
                               IsVisible="{Binding Scanning}" Margin="2,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding Devices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:BluetoothDeviceItemViewModel">
                                <Border CornerRadius="14" Margin="0,0,0,6" Padding="12,8"
                                        Background="{DynamicResource RowFill}">
                                    <Grid ColumnDefinitions="38,*,Auto">
                                        <!-- connected: accent; idle: muted -->
                                        <Panel Grid.Column="0" Width="22" Height="22" VerticalAlignment="Center">
                                            <controls:LucideIcon Kind="{Binding IconKind}" Width="22" Height="22"
                                                                 IsVisible="{Binding Connected}"
                                                                 Brush="{DynamicResource AccentBrush}"/>
                                            <controls:LucideIcon Kind="{Binding IconKind}" Width="22" Height="22"
                                                                 IsVisible="{Binding !Connected}"
                                                                 Brush="{DynamicResource TextMuted}"/>
                                        </Panel>
                                        <StackPanel Grid.Column="1" Margin="8,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="15"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Spacing="5"
                                                        IsVisible="{Binding Connected}">
                                                <controls:LucideIcon Kind="circle-check" Width="12" Height="12"
                                                                     VerticalAlignment="Center"
                                                                     Brush="{DynamicResource AccentBrush}"/>
                                                <TextBlock Text="conectado" FontSize="12"
                                                           Foreground="{DynamicResource AccentBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button Grid.Column="2" Classes="pill" MinHeight="40" Padding="14,8"
                                                Command="{Binding $parent[ItemsControl].((vm:BluetoothViewModel)DataContext).ToggleCommand}"
                                                CommandParameter="{Binding}">
                                            <Panel>
                                                <TextBlock Text="Desconectar" IsVisible="{Binding Connected}"/>
                                                <TextBlock Text="Conectar" IsVisible="{Binding !Connected}"/>
                                            </Panel>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
