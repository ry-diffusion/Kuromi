<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Kuromi.App"
             xmlns:local="using:Kuromi"
             xmlns:conv="using:Kuromi.Converters"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Kuromi/Styles/Palette.axaml"/>
                <ResourceInclude Source="avares://Kuromi/Assets/Icons.axaml"/>
            </ResourceDictionary.MergedDictionaries>

            <conv:BytesToHumanConverter x:Key="BytesToHuman"/>
            <conv:PathToBitmapConverter x:Key="PathToBitmap"/>
            <conv:StringToBrushConverter x:Key="StringToBrush"/>
            <conv:WidgetKindToTitleConverter x:Key="WidgetKindToTitle"/>

            <!-- App font (Funnel Sans, statically instanced weights bundled in Assets/Fonts) -->
            <FontFamily x:Key="AppFont">avares://Kuromi/Assets/Fonts/#Funnel Sans</FontFamily>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Kuromi/Styles/KuromiTheme.axaml"/>
    </Application.Styles>
</Application>
